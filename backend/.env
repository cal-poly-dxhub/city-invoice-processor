# AWS Configuration
AWS_REGION=us-west-2
AWS_PROFILE=

# Bedrock Model (REQUIRED)
# For us-west-2, use: us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bedrock Vision Model (for table detection - faster/cheaper)
# Nova 2 Lite is ~10x cheaper and faster than Sonnet for simple vision classification
BEDROCK_VISION_MODEL_ID=us.amazon.nova-lite-v1:0

# Text Extraction
TEXT_MIN_CHARS=40
TEXTRACT_MODE=auto
TEXTRACT_MAX_LINES=300

# Table Detection (uses Bedrock vision to detect table pages before PyMuPDF)
# Set to "true" to enable pre-detection of table-heavy pages for direct Textract routing
TABLE_DETECTION_ENABLED=false

# PyMuPDF Table Extraction (quality thresholds for when to use PyMuPDF vs fall back to Textract)
MIN_TABLE_ROWS=2                    # Minimum rows required for valid table
MIN_TABLE_CELLS=4                   # Minimum total cells (e.g., 2x2 table)
MIN_TABLE_CELL_COVERAGE=0.5         # Minimum ratio of non-empty cells (0.5 = 50%)
PYMUPDF_TABLE_STRATEGY=lines        # lines | text | lines_strict (detection strategy)

# Processing
MAX_WORKERS=3

# Output
OUTPUT_DIR=jobs
MIN_CANDIDATE_SCORE=0.4
